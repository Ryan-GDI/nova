# Copy this file to ".env" and paste in your real key.
# Get a key at https://console.anthropic.com  (Settings -> API Keys)

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional - change the model Nova uses.
# Faster/cheaper: claude-haiku-4-5   |   Smarter: claude-opus-4-8
MAY_MODEL=claude-sonnet-4-6

# Optional - durable cross-device memory (free at https://console.upstash.com).
# Create a Redis database, then copy its REST URL and REST token here.
# Without these, memory still works but resets when the free server sleeps/redeploys.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

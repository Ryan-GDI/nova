# Copy to ".env" for local use. On Render, set these in the Environment tab instead.

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional model choice
MAY_MODEL=claude-sonnet-4-6

# Passcode lock (set this to require a passcode)
NOVA_PASSCODE=

# Durable cross-device memory (free at https://console.upstash.com -> Redis -> REST API)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Document letterhead branding (used for Word/PDF generation)
NOVA_BRAND_NAME=Global Deal Inc.
NOVA_BRAND_TAGLINE=International Sourcing & Supply
NOVA_BRAND_CONTACT=Sandton, Johannesburg
# Optional: drop a logo at public/brand-logo.png (PNG) to add it to the letterhead
